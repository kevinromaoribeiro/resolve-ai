# ===== Evolution API (WhatsApp via QR Code) =====
EVOLUTION_APIKEY=troque-esta-chave-por-algo-longo
EVOLUTION_INSTANCE=resolveai
EVOLUTION_URL=http://localhost:8080

# ===== IA (opcional — sem chave, roda em Mock) =====
# OPENAI_API_KEY=sk-...          # gpt-4o-mini + Whisper (áudio) + visão (fotos)
# ANTHROPIC_API_KEY=sk-ant-...   # claude-3-haiku + visão (fotos)

# ===== Monetização & Admin =====
PAYMENT_LINK=https://pay.kirvano.com/SEU-PRODUTO      # ou Mercado Pago Assinaturas
PAYMENT_LINK_ANUAL=                                    # opcional
TRIAL_DAYS=7
ADMIN_PHONE=5511999990000    # SEU número: pode mandar "ativar <telefone>" no bot

# --- v6 ---------------------------------------------------------------
# Teto de duração de áudio aceito (segundos). Acima disso o bot pede texto.
AUDIO_MAX_SECONDS=120
# URL pública dos Termos de Uso + Política de Privacidade (LGPD)
TERMS_URL=https://kevinromaoribeiro.github.io/resolveai-site/termos.html
# E-mail de contato LGPD: resolveai0@gmail.com

# --- VPS (deploy 24/7) ------------------------------------------------
# IP público da sua VPS, com http:// e :8080. Ex.: http://203.0.113.45:8080
# Em PC local, deixe em branco (usa localhost automaticamente).
SERVER_URL=
